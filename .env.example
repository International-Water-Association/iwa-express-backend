PORT=5000

# Comma-separated frontend origins. Do not include paths.
FRONTEND_ALLOWED_ORIGINS=http://localhost:4200,https://partial.iwaconnectplus.com,https://event.iwaconnectplus.org,https://www.iwaconnectplus.com

# Target Strapi/Event API base URL. Include /api if your target routes start after /api.
STRAPI_URL=https://partial.iwaconnectplus.com/api

# Server-side tokens. These must never be exposed to Angular.
EVENT_API_TOKEN=replace_with_event_api_token
WEBINAR_API_TOKEN=replace_with_webinar_api_token

# JWT secrets. Use long random values in production.
PROXY_JWT_SECRET=replace_with_long_random_proxy_secret
PROXY_JWT_EXPIRES_SECONDS=120

EVENT_GUEST_JWT_SECRET=replace_with_long_random_guest_secret
EVENT_GUEST_JWT_EXPIRES_SECONDS=900

PROXY_MAX_BODY_BYTES=10000
PROXY_TIMEOUT_MS=10000
